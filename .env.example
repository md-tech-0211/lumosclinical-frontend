# Copy to .env.local for local dev. In Vercel: Project → Settings → Environment Variables.

# --- Monday MCP + REST API on the same host ---
# Set MONDAY_MCP_URL to your MCP HTTP endpoint (e.g. http://localhost:3001/api/mcp).
# Do not use https://localhost unless the MCP has a real trusted cert — Node fetch will usually fail.
# Leads/deals/settings proxies use the same origin with path /api/v1 automatically.
# Override only if the REST API lives elsewhere:
# BACKEND_API_BASE=http://other-host:8000/api/v1
MONDAY_MCP_URL=

# Optional: same Monday.com API v2 token as on the MCP server (MONDAY_TOKEN or MONDAY_API_TOKEN).
# When set on this Next.js app, /api/ai/monday exposes lumos_search_person_by_item_name — a fast
# server-side name filter (no full-board scan). Without it, lookups rely on MCP get_board_items_by_name only.
# MONDAY_TOKEN=
# Optional override for the GraphQL endpoint (default https://api.monday.com/v2).
# MONDAY_API_URL=

# --- REST API override (optional) ---
# If unset, BACKEND_API_BASE is derived from MONDAY_MCP_URL (same scheme/host/port → /api/v1).
# BACKEND_API_BASE=

# --- AWS Bedrock (used by /api/ai/monday) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# BEDROCK_MODEL_ID is optional. Default is the US inference profile for Claude Sonnet 4.5:
#   us.anthropic.claude-sonnet-4-5-20250929-v1:0
# (Raw model IDs like anthropic.claude-sonnet-4-5-... often fail with on-demand errors;
# use the inference profile ID or ARN from Bedrock → Model access / list-inference-profiles.)
# EU example: eu.anthropic.claude-sonnet-4-5-20250929-v1:0
# Cheaper / older models may still accept a plain foundation model ID:
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# --- Optional: analysis HTTP API (Lambda / internal API for prescreen eligibility) ---
# Luna assistant (/api/ai/monday) exposes tool `analysis_invoke` when this is set.
# If you run a separate Monday MCP server (e.g. Vercel) that also lists `analysis_invoke`,
# set the SAME variables there so MCP clients and Luna both call the same backend.
# ANALYSIS_FUNCTION_URL=https://your-api.example.com/analysis
# Optional Authorization header value (e.g. Bearer …):
# ANALYSIS_FUNCTION_AUTH_HEADER=
# Implementation reference in this repo: lib/analysis-invoke-http.ts (runAnalysisInvokeHttp).
