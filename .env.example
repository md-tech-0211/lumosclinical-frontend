# Copy to .env.local for local dev. In Vercel: Project → Settings → Environment Variables.

# --- Monday MCP (must be reachable from the internet in production, not localhost) ---
# Example production: https://your-mcp-server.example.com/mcp
MONDAY_MCP_URL=

# --- AWS Bedrock (used by /api/ai/monday) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
